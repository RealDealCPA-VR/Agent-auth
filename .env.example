# ===========================================================================
# AgentAuth configuration. Copy to .env and fill in the secrets.
# The process refuses to boot if MASTER_KEY or JWT_SECRET is missing/malformed.
# ===========================================================================

# --- Database (matches docker-compose.yml; host port 5433 to avoid clashing
#     with a local 5432) ---
DATABASE_URL=postgres://agentauth:agentauth@localhost:5433/agentauth

# Postgres TLS: disable | require | verify. Defaults to "require" when
# NODE_ENV=production, otherwise "disable". For "verify", point at a CA bundle.
# DATABASE_SSL=disable
# DATABASE_SSL_CA=/path/to/ca.pem

# --- Master key encryption key (KEK) ---
# 32 random bytes, base64-encoded. Wraps every passport's data key (DEK).
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEVER commit the real value. Losing it makes every stored credential unrecoverable.
MASTER_KEY=
# Identifier for the active KEK (recorded on each wrapped DEK so keys can rotate).
MASTER_KEY_ID=k1
# Optional retired KEKs for rotation, as JSON: {"k0":"<base64-32B>"}
# MASTER_KEYS_RETIRED=

# --- Key provider for the KEK layer (wraps per-passport data keys) ---
# local — wrap with MASTER_KEY in-process (default)
# kms   — wrap via AWS KMS; the KEK never enters this process. Install the optional
#         dependency @aws-sdk/client-kms and set KMS_KEY_ID (+ region/endpoint).
KEY_PROVIDER=local
# KMS_KEY_ID=arn:aws:kms:...:key/...
# KMS_REGION=us-east-1
# KMS_ENDPOINT=                       # override for LocalStack / tests

# --- Human session JWT signing secret ---
# 32 random bytes, base64-encoded.
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=
JWT_KEY_ID=j1
# Optional retired JWT keys for rotation, JSON {"<kid>":"<base64-32B>"}
# JWT_SECRETS_RETIRED=
# Session token lifetime in seconds (max 86400). Default 1h.
JWT_TTL_SECONDS=3600

# --- Audit hash-chain signing key (versioned, rotatable) ---
# Active key: AUDIT_HMAC_SECRET if set (32B base64), else derived from MASTER_KEY.
# AUDIT_HMAC_SECRET=
AUDIT_KEY_ID=a1
# Retired audit keys, JSON {"<kid>":"<base64-32B>"} — keep as long as you retain history.
# AUDIT_KEYS_RETIRED=

# --- OAuth credential capture (optional) ---
# JSON registry of providers; AgentAuth runs the auth-code flow and stores tokens.
# OAUTH_PROVIDERS={"github":{"authUrl":"https://github.com/login/oauth/authorize","tokenUrl":"https://github.com/login/oauth/access_token","clientId":"...","clientSecret":"...","scopes":["repo"]}}
# OAUTH_REDIRECT_BASE=http://localhost:8080
# OAUTH_STATE_TTL_SECONDS=600
# Timeout (ms) for OAuth token-endpoint calls — bounds how long a slow provider
# can pin a DB connection + lock during a refresh.
# OAUTH_TOKEN_TIMEOUT_MS=15000

# --- Per-credential approval workflow ---
# How long an approval grant / pending request stays valid (seconds).
APPROVAL_TTL_SECONDS=900

# --- mTLS agent identity (optional) ---
# Let agents authenticate with a client certificate instead of a bearer key.
# MTLS_ENABLED=false
# MTLS_CA=/path/to/client-ca.pem      # required in native mode (server verifies client certs)
# MTLS_TRUSTED_PROXY=false            # true if a proxy terminates mTLS and forwards the fingerprint
# MTLS_FP_HEADER=x-client-cert-fingerprint

# --- Proxy mode ---
# Server-side credential injection: AgentAuth makes the downstream call for an
# agent (scope vault:proxy) so the secret never reaches the agent. The host is
# pinned to the credential's target; redirects are not followed.
# Max time for the downstream request, in milliseconds.
PROXY_TIMEOUT_MS=15000
# Max downstream response size buffered/returned, in bytes (default 5 MiB).
PROXY_MAX_RESPONSE_BYTES=5242880
# Allow proxying a secret over plaintext http:// to non-loopback hosts. Keep false.
PROXY_ALLOW_HTTP=false
# Allow proxying to private / link-local / cloud-metadata hosts. Keep false.
PROXY_ALLOW_PRIVATE=false

# --- HTTP / security ---
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
# Native TLS: set BOTH to PEM file paths to terminate HTTPS in-process.
# Leave unset to serve HTTP behind a TLS-terminating reverse proxy / load balancer.
# HTTPS_CERT=/path/to/fullchain.pem
# HTTPS_KEY=/path/to/privkey.pem
# Max JSON request body size in bytes.
BODY_LIMIT_BYTES=65536
# Comma-separated CORS allowlist (empty = no cross-origin browser access).
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# --- Rate limiting (requests per window) ---
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_WINDOW=1 minute

# --- Lifecycle ---
SHUTDOWN_TIMEOUT_MS=10000
