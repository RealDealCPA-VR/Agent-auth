# ===========================================================================
# AgentAuth configuration. Copy to .env and fill in the secrets.
# The process refuses to boot if MASTER_KEY or JWT_SECRET is missing/malformed.
# ===========================================================================

# --- Database (matches docker-compose.yml; host port 5433 to avoid clashing
#     with a local 5432) ---
DATABASE_URL=postgres://agentauth:agentauth@localhost:5433/agentauth

# Postgres TLS: disable | require | verify. Defaults to "require" when
# NODE_ENV=production, otherwise "disable". For "verify", point at a CA bundle.
# DATABASE_SSL=disable
# DATABASE_SSL_CA=/path/to/ca.pem

# --- Master key encryption key (KEK) ---
# 32 random bytes, base64-encoded. Wraps every passport's data key (DEK).
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEVER commit the real value. Losing it makes every stored credential unrecoverable.
MASTER_KEY=
# Identifier for the active KEK (recorded on each wrapped DEK so keys can rotate).
MASTER_KEY_ID=k1
# Optional retired KEKs for rotation, as JSON: {"k0":"<base64-32B>"}
# MASTER_KEYS_RETIRED=

# --- Human session JWT signing secret ---
# 32 random bytes, base64-encoded.
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=
# Session token lifetime in seconds (max 86400). Default 1h.
JWT_TTL_SECONDS=3600

# --- HTTP / security ---
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
# Max JSON request body size in bytes.
BODY_LIMIT_BYTES=65536
# Comma-separated CORS allowlist (empty = no cross-origin browser access).
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# --- Rate limiting (requests per window) ---
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_WINDOW=1 minute

# --- Lifecycle ---
SHUTDOWN_TIMEOUT_MS=10000
