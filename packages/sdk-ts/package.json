{
  "name": "@agentauth/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for AgentAuth — the agent credential vault. One-line useCredential(target) for agents, plus a thin human-side admin client.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RealDealCPA-VR/Agent-auth.git",
    "directory": "packages/sdk-ts"
  },
  "homepage": "https://github.com/RealDealCPA-VR/Agent-auth/tree/main/packages/sdk-ts#readme",
  "bugs": {
    "url": "https://github.com/RealDealCPA-VR/Agent-auth/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentauth",
    "credentials",
    "vault",
    "ai-agents",
    "secrets",
    "sdk"
  ],
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
