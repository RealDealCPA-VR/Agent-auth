{
  "name": "@agentauth/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for AgentAuth — the agent credential vault. One-line useCredential(target) for agents, plus a thin human-side admin client.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "agentauth",
    "credentials",
    "vault",
    "ai-agents",
    "secrets",
    "sdk"
  ],
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
